# Server
PORT=4317
HOST=127.0.0.1
APP_BASE_URL=http://localhost:4317
APP_AUTH_TOKEN=
INITIAL_ADMIN_USERNAME=chenbk1
INITIAL_ADMIN_PASSWORD=123456
AUTH_SESSION_DAYS=14

# Microsoft Graph delegated OAuth.
# Register a Microsoft Entra app and add this redirect URI:
# http://localhost:4317/api/outlook/callback
MS_TENANT_ID=organizations
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_PUBLIC_CLIENT_ID=14d82eec-204b-4c2f-b7e8-296a70dab67e
MS_REDIRECT_URI=http://localhost:4317/api/outlook/callback
MS_SCOPES="offline_access User.Read Mail.Read Calendars.ReadWrite"

# Aliyun Bailian / DashScope OpenAI-compatible endpoint.
# Keep the real key only in .env or secret manager. Do not commit it.
BAILIAN_OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
BAILIAN_API_KEY=
BAILIAN_MODEL=qwen3.6-plus

# Feishu/Lark Base intake form sync.
# Keep profile explicit so this recruiting project does not use another team's bot.
LARK_CLI_PATH=lark-cli
LARK_CLI_PROFILE=cli_a955ff0940789cca
LARK_CLI_AS=bot
LARK_BASE_TOKEN=
LARK_TABLE_ID=
LARK_VIEW_ID=
LARK_FORM_SHARE_URL=
LARK_RESUME_FIELD=简历
LARK_SYNC_LIMIT=100

# Existing Feishu interview sheet sync. Hidden by default because it is only a
# historical backfill helper, not the current intake path.
INTERVIEW_SHEET_ENABLED=false
INTERVIEW_SHEET_CLI_PROFILE=cli_a955ff0940789cca
INTERVIEW_SHEET_CLI_AS=bot
INTERVIEW_SHEET_URL=
INTERVIEW_SPREADSHEET_TOKEN=
INTERVIEW_SHEET_ID=
